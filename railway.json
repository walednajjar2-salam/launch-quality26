{
  "$schema": "https://railway.app/railway.schema.json",
  "deploy": {
    "startCommand": "python server.py",
    "restartPolicyType": "always",
    "restartPolicyMaxRetries": 5
  },
  "env": {
    "JAWDAH_HOST": {
      "description": "Server host",
      "value": "0.0.0.0"
    },
    "JAWDAH_PORT": {
      "description": "Server port",
      "value": "8080"
    },
    "JAWDAH_DATA_DIR": {
      "description": "Data directory path",
      "value": "/var/data"
    }
  },
  "volumes": [
    {
      "name": "jawdah-data",
      "mountPath": "/var/data"
    }
  ]
}
